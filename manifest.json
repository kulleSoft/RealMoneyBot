{
  "manifest_version": 3,
  "name": "RealMoney Bot",
  "short_name": "RealMoney Bot",
  "version": "1.0.0",
  "description": "Automação de faucets por KulleSoft — claimfreecoins.io · beefaucet.org",
  "author": "KulleSoft",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "alarms",
    "notifications",
    "declarativeNetRequest",
    "idle"
  ],
  "host_permissions": [
    "https://claimfreecoins.io/*",
    "https://beefaucet.org/*",
    "https://thanks.notsync.io/*",
    "*://*.google.com/recaptcha/*",
    "*://*.recaptcha.net/recaptcha/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "RealMoney Bot — KulleSoft",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claimfreecoins.io/*",
        "https://beefaucet.org/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.google.com/recaptcha/*",
        "*://*.recaptcha.net/recaptcha/*"
      ],
      "js": [
        "iacaptchar/eventhook.js",
        "iacaptchar/captcha/recaptcha.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "iacaptchar/models/type.onnx",
        "iacaptchar/models/grid.onnx",
        "iacaptchar/models/grid.meta.json",
        "iacaptchar/lib/sql-wasm.wasm",
        "iacaptchar/lib/sql-wasm.js",
        "iacaptchar/lib/sql-wasm-wrapper.js",
        "iacaptchar/lib/sql-wasm.mjs",
        "iacaptchar/db/captcha.sqlite",
        "iacaptchar/background_sqlite.js",
        "iacaptchar/captcha/phash-browser.js",
        "iacaptchar/libs/onnxruntime-web/**",
        "iacaptchar/captcha/recaptcha_ai.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_page": "options.html"
}
